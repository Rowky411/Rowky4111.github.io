              <span>X (Twitter)</span>
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>
</Layout>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement;
  const successMsg = document.getElementById('success-msg') as HTMLElement;

  function showFloat(inputId: string, labelId: string) {
    const input = document.getElementById(inputId) as HTMLInputElement | HTMLTextAreaElement;
    const label = document.getElementById(labelId) as HTMLElement;
    input.addEventListener('input', () => {
      label.style.display = input.value ? 'block' : 'none';
    });
  }
  showFloat('f-name', 'lbl-name');
  showFloat('f-email', 'lbl-email');
  showFloat('f-msg', 'lbl-msg');

  function setError(errId: string, msg: string, inputId: string) {
    const errEl = document.getElementById(errId) as HTMLElement;
    const input = document.getElementById(inputId) as HTMLInputElement | HTMLTextAreaElement;
    errEl.textContent = msg;
    input.style.borderColor = msg ? '#E06B74' : '#ABB2BF';
  }

  form.addEventListener('submit', (e) => {
    e.preventDefault();
    const name = (document.getElementById('f-name') as HTMLInputElement).value.trim();
    const email = (document.getElementById('f-email') as HTMLInputElement).value.trim();
    const msg = (document.getElementById('f-msg') as HTMLTextAreaElement).value.trim();

    let valid = true;
    if (!name) { setError('err-name', 'Name is required', 'f-name'); valid = false; }
    else { setError('err-name', '', 'f-name'); }

    if (!email || !email.includes('@')) { setError('err-email', 'Valid email required', 'f-email'); valid = false; }
    else { setError('err-email', '', 'f-email'); }

    if (!msg) { setError('err-msg', 'Message cannot be empty', 'f-msg'); valid = false; }
    else { setError('err-msg', '', 'f-msg'); }

    if (valid) {
      form.style.display = 'none';
      successMsg.style.display = 'block';
    }
  });
</script>

<style>
  .page-title { margin-bottom: 48px; }
  .page-title-heading { display: flex; align-items: baseline; }
  .slash { font-size: 32px; font-weight: 700; color: #C778DD; line-height: 1; }
  .slug { font-size: 32px; font-weight: 700; color: #fff; line-height: 1; }
  .subtitle { font-size: 16px; color: #ABB2BF; margin-top: 8px; }

  .contacts-layout { display: flex; gap: 64px; flex-wrap: wrap; align-items: flex-start; }

  /* Form */
  .form-section { flex: 1; min-width: 280px; max-width: 480px; }
  .contact-form { display: flex; flex-direction: column; gap: 24px; }
  .field-wrap { position: relative; }
  .float-label {
    position: absolute; top: -9px; left: 9px;
    background: #282C33; padding: 0 4px;
    font-size: 12px; color: #C778DD;
    font-family: 'Space Mono', monospace;
  }
  .field-input {
    border: 1px solid #ABB2BF; padding: 10px 12px;
    font-size: 15px; color: #fff; background: transparent;
    width: 100%; outline: none; transition: border-color 0.2s;
    font-family: 'Space Mono', monospace;
  }
  .field-input:focus { border-color: #fff; }
  .field-textarea { height: 140px; resize: none; }
  .field-error { font-size: 11px; color: #E06B74; margin-top: 4px; min-height: 16px; }

  .submit-btn { align-self: flex-start; }

  .success-msg {
    border: 1px solid #C778DD; padding: 24px;
    font-size: 15px; color: #C778DD; line-height: 1.7;
  }
  .success-title { font-weight: 700; margin-bottom: 8px; }

  /* Contact details */
  .contact-details { flex: 0 0 260px; }
  .details-stack { display: flex; flex-direction: column; gap: 16px; }
  .detail-card { border: 1px solid #ABB2BF; padding: 20px; }
  .detail-card-title { font-size: 14px; font-weight: 700; color: #fff; margin-bottom: 16px; }
  .detail-items { display: flex; flex-direction: column; gap: 14px; }
  .detail-item { display: flex; align-items: flex-start; gap: 10px; font-size: 13px; color: #ABB2BF; line-height: 1.5; }
  .detail-link { color: #ABB2BF; text-decoration: none; transition: color 0.2s; }
  .detail-link:hover { color: #fff; }

  .detail-socials { display: flex; flex-direction: column; gap: 12px; }
  .social-row {
    display: flex; align-items: center; gap: 10px;
    color: #ABB2BF; font-size: 13px; text-decoration: none;
    transition: color 0.2s;
  }
  .social-row:hover { color: #fff; }
  .social-row svg { opacity: 0.8; }
</style>
