---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Contacts — Jurayak Kader" activePage="contacts">
  <div class="page-title">
    <div class="page-title-heading">
      <span class="slash">/</span><span class="slug">contacts</span>
    </div>
    <div class="subtitle">Get in touch</div>
  </div>

  <div class="contacts-layout">
    <!-- Form -->
    <div class="form-section">
      <div class="section-heading">
        <span class="hash">#</span>
        <span class="title">contact-me</span>
        <div class="line"></div>
      </div>

      <div id="success-msg" class="success-msg" style="display:none;">
        <div class="success-title">Message sent!</div>
        I'll get back to you as soon as possible.
      </div>

      <form id="contact-form" class="contact-form" novalidate>
        <div class="field-wrap">
          <label class="float-label" id="lbl-name" style="display:none;">Name</label>
          <input id="f-name" type="text" placeholder="Name" class="field-input" />
          <div class="field-error" id="err-name"></div>
        </div>
        <div class="field-wrap">
          <label class="float-label" id="lbl-email" style="display:none;">Email</label>
          <input id="f-email" type="email" placeholder="Email" class="field-input" />
          <div class="field-error" id="err-email"></div>
        </div>
        <div class="field-wrap">
          <label class="float-label" id="lbl-msg" style="display:none;">Message</label>
          <textarea id="f-msg" placeholder="Your message..." class="field-input field-textarea"></textarea>
          <div class="field-error" id="err-msg"></div>
        </div>
        <button type="submit" class="btn submit-btn">Send message -&gt;</button>
      </form>
    </div>

    <!-- Contact details -->
    <div class="contact-details">
      <div class="section-heading">
        <span class="hash">#</span>
        <span class="title">reach-me</span>
        <div class="line"></div>
      </div>

      <div class="details-stack">
        <div class="detail-card">
          <div class="detail-card-title">Direct contact</div>
          <div class="detail-items">
            <a href="mailto:jurayakkader.uiu@gmail.com" class="detail-item detail-link">
