---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import MediaSidebar from '../components/MediaSidebar.astro';

const { title = 'Jurayak Kader — Software Engineer', activePage } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
  </head>
  <body>
    <MediaSidebar />

    <!-- fixed bg dots -->
    <div style="position:fixed;right:16px;top:100px;opacity:0.1;pointer-events:none;z-index:0;">
      <div class="dot-grid" style="grid-template-columns:repeat(5,5px);gap:9px;">
        {Array.from({length:25}).map((_,i) => (
          <div class="dot" style="width:5px;height:5px;background:#ABB2BF;"></div>
        ))}
      </div>
    </div>
    <div style="position:fixed;left:56px;bottom:100px;opacity:0.07;pointer-events:none;z-index:0;">
      <div class="dot-grid" style="grid-template-columns:repeat(4,5px);gap:9px;">
        {Array.from({length:16}).map((_,i) => (
          <div class="dot" style="width:5px;height:5px;background:#ABB2BF;"></div>
        ))}
      </div>
    </div>

    <div style="max-width:1040px;margin:0 auto;padding:0 32px 0 72px;position:relative;z-index:1;">
      <Header activePage={activePage} />
      <main style="padding-top:52px;padding-bottom:32px;">
        <slot />
      </main>
      <Footer />
    </div>

    <script>
      import gsap from 'gsap';
      import { ScrollTrigger } from 'gsap/ScrollTrigger';

      gsap.registerPlugin(ScrollTrigger);

      const ease = 'power3.out';

      function wrapLines(el) {
        const lines = el.innerHTML.split(/<br\s*\/?>/i);
        el.innerHTML = lines.map(l =>
          `<span style="display:block;overflow:hidden;"><span class="line-inner" style="display:block;">${l}</span></span>`
        ).join('');
        return el.querySelectorAll('.line-inner');
      }

      /* ── Header entrance ── */
      const logo = document.querySelector('header a');
      const navLinks = document.querySelectorAll('.nav-link');
      const sidebar = document.querySelector('.media-sidebar');
      gsap.from([logo, ...navLinks].filter(Boolean), { y: -22, opacity: 0, duration: 0.55, stagger: 0.07, ease, delay: 0.1 });
      if (sidebar) gsap.from(sidebar, { x: -30, opacity: 0, duration: 0.6, ease, delay: 0.2 });

      /* ── Hero entrance (home only) ── */
      const label    = document.querySelector('.hero-label');
      const titleEl  = document.querySelector('.hero-title');
      const desc     = document.querySelector('.hero-desc');
      const btns     = document.querySelector('.hero-btns');
      const photo    = document.querySelector('.hero-photo');
      const decoRects = document.querySelectorAll('.deco-rect');
      const badge    = document.querySelector('.status-badge');

      if (label) {
        const lineInners = titleEl ? wrapLines(titleEl) : [];
        gsap.timeline({ defaults: { ease }, delay: 0.25 })
          .from(label,  { y: 24, opacity: 0, duration: 0.55 })
          .from(lineInners, { y: '110%', duration: 0.65, stagger: 0.1 }, '-=0.25')
          .from(desc,   { y: 18, opacity: 0, duration: 0.5 }, '-=0.3')
          .from(btns ? [...btns.children] : [], { y: 16, opacity: 0, duration: 0.45, stagger: 0.1 }, '-=0.3')
          .from([...decoRects], { scale: 0, opacity: 0, transformOrigin: 'top left', duration: 0.45, stagger: 0.08, ease: 'back.out(1.6)' }, '-=0.5')
          .from(photo,  { x: 60, opacity: 0, duration: 0.8, ease }, '-=0.65')
          .from(badge,  { y: 14, opacity: 0, duration: 0.45 }, '-=0.3');
      }

      /* ── Page title (projects / about / contacts) ── */
      const slash    = document.querySelector('.page-title .slash');
      const slugEl   = document.querySelector('.page-title .slug');
      const subtitle = document.querySelector('.page-title .subtitle');
      if (slugEl) {
        gsap.from([slash, slugEl].filter(Boolean), { y: 28, opacity: 0, duration: 0.6, stagger: 0.07, ease, delay: 0.2 });
        if (subtitle) gsap.from(subtitle, { y: 14, opacity: 0, duration: 0.45, ease, delay: 0.5 });
      }

      /* ── Section headings: slide + line extends ── */
      document.querySelectorAll('.section-heading').forEach(el => {
        const st = { trigger: el, start: 'top 87%', toggleActions: 'play none none none' };
        gsap.from([el.querySelector('.hash'), el.querySelector('.title')].filter(Boolean),
          { x: -30, opacity: 0, duration: 0.55, stagger: 0.07, ease, scrollTrigger: st });
        const line = el.querySelector('.line');
        if (line) gsap.from(line, { scaleX: 0, transformOrigin: 'left center', duration: 0.9, ease: 'power3.inOut', scrollTrigger: st });
      });

      /* ── Project & research cards: stagger fade-up ── */
      document.querySelectorAll('.projects-grid, .research-grid').forEach(grid => {
        gsap.from([...grid.children], {
          y: 50, opacity: 0, duration: 0.6, stagger: 0.1, ease,
          scrollTrigger: { trigger: grid, start: 'top 83%', toggleActions: 'play none none none' },
        });
      });
      document.querySelectorAll('.project-card, .research-card').forEach(card => {
        card.addEventListener('mouseenter', () => gsap.to(card, { y: -7, duration: 0.3, ease: 'power2.out' }));
        card.addEventListener('mouseleave', () => gsap.to(card, { y:  0, duration: 0.35, ease: 'power2.inOut' }));
      });

      /* ── Skill boxes: pop in with bounce ── */
      document.querySelectorAll('.skills-grid').forEach(grid => {
        const boxes = grid.querySelectorAll('.skill-box');
        if (boxes.length) gsap.from(boxes, {
          scale: 0.82, opacity: 0, duration: 0.45, stagger: 0.06, ease: 'back.out(1.5)',
          scrollTrigger: { trigger: grid, start: 'top 86%', toggleActions: 'play none none none' },
        });
      });

      /* ── About: text from left, photo from right ── */
      ['.about-row', '.bio-row'].forEach(sel => {
        const row = document.querySelector(sel);
        if (!row) return;
        const st = { trigger: row, start: 'top 82%', toggleActions: 'play none none none' };
        const textEl  = row.querySelector('.about-text, .bio-text');
        const photoEl = row.querySelector('.about-photo-wrap, .bio-photo-wrap');
        if (textEl)  gsap.from(textEl,  { x: -38, opacity: 0, duration: 0.7, ease, scrollTrigger: st });
        if (photoEl) gsap.from(photoEl, { x:  38, opacity: 0, duration: 0.7, ease, scrollTrigger: st });
      });

      /* ── Experience & Education: slide from left ── */
      ['.exp-list', '.edu-list'].forEach(sel => {
        const list = document.querySelector(sel);
        if (!list) return;
        gsap.from([...list.children], {
          x: -30, opacity: 0, duration: 0.5, stagger: 0.1, ease,
          scrollTrigger: { trigger: list, start: 'top 86%', toggleActions: 'play none none none' },
        });
      });

      /* ── Quick facts: pop in ── */
      const factsList = document.querySelector('.facts-list');
      if (factsList) gsap.from([...factsList.children], {
        scale: 0.7, opacity: 0, duration: 0.38, stagger: 0.05, ease: 'back.out(1.8)',
        scrollTrigger: { trigger: factsList, start: 'top 88%', toggleActions: 'play none none none' },
      });

      /* ── Contact form fields ── */
      const fields = document.querySelectorAll('.field-wrap');
      if (fields.length) gsap.from(fields, {
        y: 24, opacity: 0, duration: 0.45, stagger: 0.1, ease,
        scrollTrigger: { trigger: fields[0], start: 'top 86%', toggleActions: 'play none none none' },
      });
      const detailCards = document.querySelectorAll('.detail-card');
      if (detailCards.length) gsap.from(detailCards, {
        x: 26, opacity: 0, duration: 0.5, stagger: 0.12, ease,
        scrollTrigger: { trigger: detailCards[0], start: 'top 86%', toggleActions: 'play none none none' },
      });

      /* ── Footer ── */
      const footer = document.querySelector('footer');
      if (footer) gsap.from(footer, {
        y: 30, opacity: 0, duration: 0.55, ease,
        scrollTrigger: { trigger: footer, start: 'top 96%', toggleActions: 'play none none none' },
      });

      /* ── Velocity skew on scroll (GSAP demos inspired) ── */
      ScrollTrigger.create({
        onUpdate(self) {
          const skew = gsap.utils.clamp(-5, 5)(self.getVelocity() / 1000);
          gsap.to('.hero-title .line-inner, .section-heading .title', {
            skewX: skew * 0.35, duration: 0.3, ease: 'power2.out', overwrite: true,
          });
          gsap.to('.hero-title .line-inner, .section-heading .title', {
            skewX: 0, duration: 1.2, ease: 'elastic.out(1, 0.5)', delay: 0.12,
          });
        },
      });
    </script>
  </body>
</html>
